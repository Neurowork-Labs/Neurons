SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
GOOGLE_LLM_API_KEY=your_google_api_key

RAG_AGENT_INTERNAL_SECRET=generate_a_long_random_string

GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_OUTPUT_DIMENSIONALITY=1536
GEMINI_CHAT_MODEL=gemini-2.0-flash
RAG_MATCH_CHUNK_LIMIT=8
PORT=8080

# System-controlled SQL generation & verification models (not user-facing)
SQL_GEN_MODEL=model_here
SQL_GEN_PROVIDER=provider_here
SQL_VERIFIER_MODEL=model_here
SQL_VERIFIER_PROVIDER=provider_here

# LangChain SQL engine (primary Text-to-SQL path)
USE_LANGCHAIN_SQL=true
LANGCHAIN_SQL_PROVIDER=google
LANGCHAIN_SQL_MODEL=gemini-3-pro-preview

# LlamaIndex SQL engine (secondary; tried if LangChain is disabled or fails)
USE_LLAMAINDEX_SQL=false
LLAMAINDEX_SQL_PROVIDER=google
LLAMAINDEX_SQL_MODEL=gemini-2.0-flash

# Optional: comma-separated origins if the browser calls this service directly
# RAG_AGENT_CORS_ORIGINS=https://app.example.com
